.container {
  padding: 16rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  min-height: 100vh;
}
.card {
  background: rgba(255,255,255,0.08);
  border-radius: 16rpx;
  padding: 30rpx;
  border: 1px solid rgba(255,255,255,0.1);
}
.section-title {
  font-size: 28rpx;
  color: #f6d365;
  margin-bottom: 24rpx;
}
.empty {
  text-align: center;
  color: #666;
  padding: 60rpx 0;
}
.history-item {
  background: rgba(255,255,255,0.05);
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.history-name {
  color: #f6d365;
  font-size: 28rpx;
}
.history-info {
  color: #666;
  font-size: 22rpx;
  margin-top: 8rpx;
}
