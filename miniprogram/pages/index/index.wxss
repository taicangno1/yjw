.container {
  padding: 16rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  min-height: 100vh;
  color: #e8e8e8;
}
.header {
  text-align: center;
  padding: 30rpx 0;
}
.logo {
  font-size: 60rpx;
  display: block;
  margin-bottom: 10rpx;
}
.title {
  font-size: 32rpx;
  background: linear-gradient(90deg, #f6d365, #fda085);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
}
.subtitle {
  color: #888;
  font-size: 24rpx;
  margin-top: 8rpx;
  display: block;
}
.card {
  background: rgba(255,255,255,0.08);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1px solid rgba(255,255,255,0.1);
}
.section-title {
  font-size: 28rpx;
  color: #f6d365;
  margin-bottom: 24rpx;
}
.form-group {
  margin-bottom: 24rpx;
}
.label {
  display: block;
  margin-bottom: 12rpx;
  color: #aaa;
  font-size: 26rpx;
}
.input {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 10rpx;
  background: rgba(255,255,255,0.05);
  color: #fff;
  font-size: 28rpx;
}
.picker {
  padding: 20rpx 24rpx;
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 10rpx;
  background: rgba(255,255,255,0.05);
  color: #fff;
  font-size: 28rpx;
}
.radio-label {
  margin-right: 40rpx;
  color: #fff;
  font-size: 28rpx;
}
.btn-primary {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #f6d365, #fda085);
  color: #1a1a2e;
  border: none;
  border-radius: 10rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
}
.result {
  display: none;
}
.result.show {
  display: block;
  animation: fadeIn 0.5s ease;
}
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.bazi-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.bazi-item {
  flex: 1;
  text-align: center;
  background: rgba(255,255,255,0.05);
  border-radius: 8rpx;
  padding: 16rpx 8rpx;
  margin: 0 4rpx;
}
.bazi-label {
  font-size: 22rpx;
  color: #888;
}
.bazi-value {
  font-size: 26rpx;
  color: #f6d365;
  font-weight: bold;
  margin-top: 4rpx;
}
.wuxing-bar {
  display: flex;
  height: 40rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: rgba(0,0,0,0.3);
  margin: 16rpx 0;
}
.wuxing-segment {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #1a1a2e;
  font-weight: bold;
}
.wuxing-label {
  display: flex;
  justify-content: space-around;
  font-size: 22rpx;
  color: #888;
}
.bazi-detail {
  margin-top: 16rpx;
}
.detail-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  font-size: 24rpx;
}
.detail-item:last-child {
  border-bottom: none;
}
.detail-label {
  color: #888;
}
.detail-value {
  color: #f6d365;
}
.gua-info {
  text-align: center;
  padding: 30rpx;
  background: rgba(246,211,101,0.1);
  border-radius: 12rpx;
}
.gua-name {
  font-size: 40rpx;
  color: #f6d365;
  margin-bottom: 12rpx;
}
.gua-desc {
  color: #aaa;
  font-size: 24rpx;
  line-height: 1.5;
}
.filter-row {
  display: flex;
  margin-bottom: 20rpx;
}
.filter-btn {
  padding: 12rpx 24rpx;
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 30rpx;
  background: none;
  color: #888;
  font-size: 24rpx;
  margin-right: 16rpx;
}
.filter-btn.active {
  background: rgba(246,211,101,0.2);
  border-color: #f6d365;
  color: #f6d365;
}
.name-item {
  background: rgba(255,255,255,0.05);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.name-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}
.name-text {
  font-size: 32rpx;
  color: #f6d365;
  flex: 1;
}
.name-score {
  background: linear-gradient(135deg, #4ade80, #22c55e);
  color: #1a1a2e;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
  margin-left: 12rpx;
}
.yinwin-badge {
  background: linear-gradient(135deg, #a78bfa, #8b5cf6);
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  margin-left: 12rpx;
}
.name-detail {
  font-size: 22rpx;
  color: #888;
  margin-bottom: 12rpx;
}
.action-row {
  display: flex;
}
.btn-small {
  padding: 12rpx 24rpx;
  background: rgba(255,255,255,0.1);
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-right: 16rpx;
}
