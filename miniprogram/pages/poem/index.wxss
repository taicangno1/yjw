.container {
  padding: 16rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  min-height: 100vh;
}
.card {
  background: rgba(255,255,255,0.08);
  border-radius: 16rpx;
  padding: 30rpx;
  border: 1px solid rgba(255,255,255,0.1);
}
.section-title {
  font-size: 28rpx;
  color: #f6d365;
  margin-bottom: 24rpx;
}
.poem-item {
  background: rgba(255,255,255,0.03);
  border-radius: 10rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.poem-title {
  color: #f6d365;
  font-size: 26rpx;
  margin-bottom: 8rpx;
}
.poem-content {
  color: #aaa;
  font-size: 24rpx;
  line-height: 1.6;
  font-style: italic;
  margin-bottom: 12rpx;
}
.poem-name {
  color: #f6d365;
  font-size: 28rpx;
  margin-top: 8rpx;
}
