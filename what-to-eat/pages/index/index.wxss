.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F0 0%, #FFF 100%);
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FF6B35;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
}

.location-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.location-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.location-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.location-label {
  font-size: 26rpx;
  color: #999;
}

.location-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.location-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.reget-btn {
  font-size: 26rpx;
  color: #FF6B35;
  padding: 10rpx 20rpx;
}

.range-section {
  margin-bottom: 60rpx;
}

.section-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 24rpx;
  display: block;
}

.start-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.35);
}

.start-btn.disabled {
  background: #CCC;
  box-shadow: none;
}

.start-btn::after {
  border: none;
}