.container {
  min-height: 100vh;
  background: #FFF5F0;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: white;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left, .header-right {
  width: 120rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.flip-count {
  font-size: 26rpx;
  color: #FF6B35;
  float: right;
}

.card-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  justify-content: space-between;
}

.card-wrapper {
  width: 48%;
  height: 360rpx;
  margin-bottom: 20rpx;
  perspective: 1000rpx;
}

.card-inner {
  width: 100%;
  height: 100%;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.5s ease;
}

.card-wrapper.flipped .card-inner {
  transform: rotateY(180deg);
}

.card-front, .card-back {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 20rpx;
  overflow: hidden;
}

.card-front {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);
}

.question-mark {
  font-size: 80rpx;
  color: white;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.card-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.card-back {
  background: white;
  transform: rotateY(180deg);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.merchant-cover {
  width: 100%;
  height: 200rpx;
}

.merchant-info {
  padding: 16rpx;
}

.merchant-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.merchant-meta {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.rating {
  font-size: 22rpx;
  color: #FF9500;
  margin-right: 16rpx;
}

.sales {
  font-size: 22rpx;
  color: #999;
}

.merchant-tags {
  display: flex;
}

.tag {
  font-size: 18rpx;
  color: #FF6B35;
  background: #FFF0E8;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 8rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.current-merchant {
  flex: 1;
  display: flex;
  align-items: center;
}

.current-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
}

.current-info {
  display: flex;
  flex-direction: column;
}

.current-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.current-distance {
  font-size: 22rpx;
  color: #999;
}

.confirm-btn {
  width: 180rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  color: white;
  border: none;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);
}

.confirm-btn::after {
  border: none;
}